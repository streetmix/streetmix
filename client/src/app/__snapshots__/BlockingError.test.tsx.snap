exports[`BlockingError > renders AUTH_EXPIRED 1`] = `
<DocumentFragment>
  <div
    id="error"
  >
    <div
      class="error-content"
    >
      <div
        class="streetmix-logo"
      />
      <div
        class="error-text"
      >
        <h1>
          We automatically signed you out due to inactivity.
        </h1>
        <p>
          Please sign in again.
        </p>
      </div>
      <button
        class="btn btn-primary"
        type="button"
      >
        Sign in
      </button>
       
      <button
        class="btn btn-primary"
        type="button"
      >
        Return to Streetmix
      </button>
    </div>
  </div>
</DocumentFragment>
`;

