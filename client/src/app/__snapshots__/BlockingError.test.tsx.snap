exports[`BlockingError > renders UNSUPPORTED_BROWSER 1`] = `
<DocumentFragment>
  <div
    id="error"
  >
    <div
      class="error-content"
    >
      <div
        class="streetmix-logo"
      />
      <div
        class="error-text"
      >
        <h1>
          Streetmix doesn’t work on your browser.
        </h1>
        <p>
          Sorry about that. You might want to try 
          <a
            href="https://www.google.com/chrome"
            rel="noopener noreferrer"
            target="_blank"
          >
            Chrome
          </a>
          , 
          <a
            href="https://www.mozilla.org/firefox"
            rel="noopener noreferrer"
            target="_blank"
          >
            Firefox
          </a>
          , 
          <a
            href="https://www.microsoft.com/en-us/windows/microsoft-edge"
            rel="noopener noreferrer"
            target="_blank"
          >
            Microsoft Edge
          </a>
          , or Safari.
        </p>
        <p>
          Are you on Internet Explorer? 
          <a
            href="https://docs.streetmix.net/user-guide/support/faq#internet-explorer"
            rel="noopener noreferrer"
            target="_blank"
          >
            Find out more.
          </a>
        </p>
        <p>
          If you think your browser should be supported, please 
          <a
            href="https://docs.streetmix.net/community"
            rel="noopener noreferrer"
            target="_blank"
          >
            contact us
          </a>
          .
        </p>
      </div>
    </div>
  </div>
</DocumentFragment>
`;
